# tests/conftest.py
import types

class FakeStyle:
    def __init__(self, name="Normal"):
        self.name = name

class FakeParagraph:
    def __init__(self, text, style_name="Normal"):
        self.text = text
        self.style = FakeStyle(style_name)
        # minimal ._p / ._element used by get_list_numbering; for tests that
        # don't touch numbering, we can keep it as simple placeholders.
        self._p = types.SimpleNamespace(pPr=None)
        self._element = types.SimpleNamespace(pPr=None)

class FakeCell:
    def __init__(self, text):
        self.text = text
        self._tc = types.SimpleNamespace(iterchildren=lambda: iter([]))

class FakeRow:
    def __init__(self, cells):
        self.cells = [FakeCell(c) for c in cells]

class FakeTable:
    def __init__(self, rows):
        self.rows = [FakeRow(r) for r in rows]

class FakeDoc:
    def __init__(self, paragraphs=None, tables=None, rels=None):
        self.paragraphs = paragraphs or []
        self.tables = tables or []
        # .part.rels used in image_text_extractor
        self.part = types.SimpleNamespace(rels=rels or {})

def make_fake_doc(paragraph_texts, paragraph_styles=None, tables=None):
    paragraph_styles = paragraph_styles or ["Normal"] * len(paragraph_texts)
    paragraphs = [FakeParagraph(t, s) for t, s in zip(paragraph_texts, paragraph_styles)]
    return FakeDoc(paragraphs=paragraphs, tables=tables or [])




# tests/test_extract_ratio.py
from utils import extract as ex

def test_ratio_extractor_finds_ratio(monkeypatch):
    fake_doc = type("D", (), {})()
    fake_doc.paragraphs = [
        type("P", (), {"text": "Randomization ratio is 2:1 for treatment vs placebo", "style": type("S", (), {"name": "Normal"})()})(),
        type("P", (), {"text": "", "style": type("S", (), {"name": "Normal"})()})(),
    ]

    monkeypatch.setattr(ex, "Document", lambda _: fake_doc)

    out = ex.ratio_extractor("x.docx")
    assert out[0]["value"] == "2:1"
    assert out[0]["score"] > 0





# tests/test_extract_amendment.py
from utils import extract as ex
from tests.conftest import FakeTable

def test_amendment_date_extractor_picks_latest(monkeypatch):
    tables = [
        FakeTable(rows=[
            ["Amendment 1", "10 Jan 2023"],
            ["Amendment 2", "05 Feb 2024"],
        ]),
        FakeTable(rows=[
            ["Amendment 2", "06 Feb 2024"],  # later date, same amendment
        ])
    ]

    fake_doc = type("D", (), {"tables": tables})()
    monkeypatch.setattr(ex, "Document", lambda _: fake_doc)

    out = ex.amendment_date_extractor("x.docx")
    assert out["amendment"] == 2
    assert out["date"] == "06 February 2024"





# tests/test_extract_age.py
from utils import extract as ex

class FakePara:
    def __init__(self, text):
        self.text = text

def test_age_extractor_range(monkeypatch):
    # Simulate: Inclusion Criteria section then age sentence then Exclusion Criteria
    blocks = [
        FakePara("Inclusion Criteria"),
        FakePara("Subjects must be 18 to 55 years of age."),
        FakePara("Exclusion Criteria"),
    ]

    monkeypatch.setattr(ex, "Document", lambda _: object())
    monkeypatch.setattr(ex, "iter_block_items", lambda doc: blocks)

    out = ex.age_extractor("x.docx")
    assert out["min_age"] == 18
    assert out["max_age"] == 55
    assert "18 to 55" in out["full_criteria_sentence"]








