def _attr(el, qname):
    """Safely read attribute value el.get(qn(...))"""
    return el.get(qname) if el is not None else None

def get_list_numbering(paragraph, doc):
    """
    Returns None if not a list paragraph; else:
      {'numId', 'ilvl', 'numFmt', 'lvlText', 'label'}
    """
    p = paragraph._p
    pPr = p.pPr if p is not None else None
    numPr = pPr.numPr if (pPr is not None and pPr.numPr is not None) else None
    if numPr is None or numPr.numId is None:
        return None

    numId = int(numPr.numId.val)
    ilvl = int(numPr.ilvl.val) if numPr.ilvl is not None else 0

    npart = doc.part.numbering_part
    if npart is None:
        return None
    root = npart.element

    # --- find <w:num w:numId="..."> ---
    num_el = None
    for n in root.findall(qn('w:num')):
        if int(_attr(n, qn('w:numId'))) == numId:
            num_el = n
            break
    if num_el is None:
        return None

    # Try <w:lvlOverride w:ilvl="..."><w:lvl>...</w:lvl> first
    numFmt = None
    lvlText = None

    for ov in num_el.findall(qn('w:lvlOverride')):
        ov_ilvl = _attr(ov, qn('w:ilvl'))
        if ov_ilvl is not None and int(ov_ilvl) == ilvl:
            lvl = ov.find(qn('w:lvl'))
            if lvl is not None:
                nf_el = lvl.find(qn('w:numFmt'))
                lt_el = lvl.find(qn('w:lvlText'))
                numFmt = _attr(nf_el, qn('w:val'))
                lvlText = _attr(lt_el, qn('w:val'))
            break

    # Fall back to abstract definition if needed
    if numFmt is None or lvlText is None:
        absId_el = num_el.find(qn('w:abstractNumId'))
        absId = _attr(absId_el, qn('w:val')) if absId_el is not None else None
        if absId is None:
            return None

        abs_el = None
        for a in root.findall(qn('w:abstractNum')):
            if _attr(a, qn('w:abstractNumId')) == absId:
                abs_el = a
                break
        if abs_el is None:
            return None

        lvl_el = None
        for lv in abs_el.findall(qn('w:lvl')):
            lv_ilvl = _attr(lv, qn('w:ilvl'))
            if lv_ilvl is not None and int(lv_ilvl) == ilvl:
                lvl_el = lv
                break

        if lvl_el is not None:
            if numFmt is None:
                nf_el = lvl_el.find(qn('w:numFmt'))
                numFmt = _attr(nf_el, qn('w:val'))
            if lvlText is None:
                lt_el = lvl_el.find(qn('w:lvlText'))
                lvlText = _attr(lt_el, qn('w:val'))

    # remove digits from lvlText format
    lvlText = ''.join(i for i in lvlText if not i.isdigit())

    label = FMT_LABELS.get(numFmt, numFmt or 'unknown')
    return {
        'numId': numId,
        'ilvl': ilvl,
        'numFmt': numFmt,     # 'decimal', 'lowerLetter', 'bullet', etc.
        'lvlText': lvlText,   # '%1.', '(%1)', '•', etc.
        'label': label,       # friendly summary
    }




def iter_block_items(parent):
    """
    Yield paragraphs and tables in document order.
    parent: Document or _Cell
    """
    if isinstance(parent, _Document):
        parent_elm = parent.element.body
    elif isinstance(parent, _Cell):
        parent_elm = parent._tc
    else:
        raise TypeError("Unknown parent type")

    for child in parent_elm.iterchildren():
        if isinstance(child, CT_P):
            yield _Paragraph(child, parent)
        elif isinstance(child, CT_Tbl):
            yield _Table(child, parent)

def iter_paragraphs_deep(parent):
    """
    Yield all Paragraphs in reading order, including those inside tables.
    """
    for block in iter_block_items(parent):
        if isinstance(block, _Paragraph):
            yield block
        elif isinstance(block, _Table):
            # Avoid visiting the same cell object multiple times (merged cells)
            seen = set()
            for row in block.rows:
                # print(len(row.cells))
                for cell in row.cells:
                    if id(cell) in seen:
                        continue
                    seen.add(id(cell))
                    # Recurse: a cell can contain paragraphs and nested tables
                    for para in iter_paragraphs_deep(cell):
                        yield para



def inclusion_text_extractor(file_path):
    section_name = "inclusion criteria"
    criteria_lbl = "IC"

    try:
        doc = Document(file_path)
        in_section = False
        crit_counter = 1
        current_crit_key = None
        criteria_dict = {}

        numbering_indent_dict = {}
        skip_lbls = []
        previous_ilvl = None

        # for block in iter_block_items(doc):
        for block in iter_paragraphs_deep(doc):
            if True:
            # if isinstance(block, _Paragraph):
                text = block.text.strip()
                if not text: continue

                # Look for inclusion/exclusion criteria heading
                # if found, we start searching for criteria
                if not in_section:
                    if section_name in text.lower() and block.style.name.startswith("Heading"):
                        section_list_numbering = get_list_numbering(block, doc)
                        in_section = True
                    continue
                
                list_numbering = get_list_numbering(block, doc)
                if list_numbering:
                    ilvl = list_numbering["ilvl"]
                    lbl = f"{list_numbering['label']} - {list_numbering['lvlText']}"
                    numFmt = list_numbering["numFmt"]
                
                # if we reach the next section heading with same numbering format, stop
                if block.style.name.startswith("Heading"):
                    if list_numbering == section_list_numbering:
                        break
                
                # the 0-level criteria numbering format must be decimal
                if not numbering_indent_dict and list_numbering and numFmt != "decimal":
                    skip_lbls.append(lbl)
                    continue
    

                if list_numbering and lbl not in skip_lbls:
                # re.match(r'^\d+(\.\d+)?[\.\)]\s+', text)

                    # print("-----")
                    # print(text)
                    # print(list_numbering)
                    # print(numbering_indent_dict)
                    # print("-----\n")
                    
                    if not numbering_indent_dict:
                        ilvl = 0
                        numbering_indent_dict[lbl] = ilvl
                    elif lbl in numbering_indent_dict:
                        ilvl = numbering_indent_dict[lbl]
                    else:
                        if ilvl in list(numbering_indent_dict.values()) and previous_ilvl is not None:
                            ilvl = previous_ilvl + 1
                        
                        numbering_indent_dict[lbl] = ilvl


                    if ilvl == 0 or not current_crit_key:
                        # New top-level IC/EX
                        current_crit_key = f"{criteria_lbl}_{crit_counter}"
                        criteria_dict[current_crit_key] = text
                        crit_counter += 1
                    else:
                        if type(criteria_dict[current_crit_key]) is str:
                            criteria_dict[current_crit_key] = {criteria_dict[current_crit_key]: [text]}
                        else:
                            item = criteria_dict[current_crit_key]
                            depth = 1
                            for _ in range(ilvl):
                                parent_item = item
                                item_list = list(item.values())[0]
                                item = item_list[-1]
                                if type(item) is str:
                                    break
                                depth += 1
                            # print("--------\n", ilvl, "\n---\n", item, "\n---\n", parent_item, "\n---\n", text, "\n---\n", parent_item[list(parent_item.keys())[0]], "\n--------")
                            if depth >= ilvl:
                                parent_item[list(parent_item.keys())[0]].append(text)
                            elif depth < ilvl:
                                parent_item[list(parent_item.keys())[0]][-1] = {item: [text]}

                    previous_ilvl = ilvl


                elif block.style.name == "Body Text" and not text.lower().startswith("note") and current_crit_key != None:
                    text = " - " + text if text[0].isupper() else " " + text
                    if type(criteria_dict[current_crit_key]) is str:
                        criteria_dict[current_crit_key] += text
                    else:
                        item = criteria_dict[current_crit_key]
                        while type(item) != str:
                            parent_item = item
                            item_list = list(item.values())[0]
                            item = item_list[-1]
                        parent_item[list(parent_item.keys())[0]][-1] += text


        return  criteria_dict

    except Exception as e:
        print(f"Error extracting styles: {str(e)}")
        # import traceback
        # traceback.print_exc()
        return {}
    


