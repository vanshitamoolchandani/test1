        numbering_indent_dict = {}
        skip_lbls = []
        
        # for block in iter_block_items(doc):
            # if isinstance(block, _Paragraph):
        for block in iter_paragraphs_deep(doc):
            text = block.text.strip()
            if not text: continue

            list_numbering = get_list_numbering(block, doc)
            # style name has to be called after list numbering, 
            # in order to trigger the lazy resolver to access all the block element properties 
            # before setting a value to style_name
            style_name = block.style.name

            # print("-----")
            # print("text:", text)
            # print("style name:", style_name)
            # print("-----\n")

            # Look for inclusion/exclusion criteria heading
            # if found, we start searching for criteria
            if not in_section:
                if section_name in text.lower() and style_name.startswith("Heading"):
                    section_list_numbering = list_numbering
                    in_section = True
                continue

            # if we reach the next section heading with same numbering format, stop
            if style_name.startswith("Heading"):
                if list_numbering == section_list_numbering:
                    break

            if list_numbering:
                ilvl = list_numbering["ilvl"]
                lbl = f"{list_numbering['label']} - {list_numbering['lvlText']}"
                numFmt = list_numbering["numFmt"]

            else:
                numbering = re.split(r"\s", text.strip())[0]
                if re.match(r'^\d+(\.\d+)?[\.\)]', numbering):
                    ilvl = 0
                    lvlText = "".join([i if i in ".)" else "%" for i in numbering])
                    lvlText = re.sub(r"%+", "%", lvlText)
                    label = "1,2,3…"
                    numFmt = "decimal"
                elif re.match(r'[a-z][\.\)]', numbering):
                    ilvl = 1
                    lvlText = "".join([i if i in ".)" else "%" for i in numbering])
                    lvlText = re.sub(r"%+", "%", lvlText)
                    label = "a,b,c…"
                    numFmt = "lowerLetter"
                elif re.match(r'[A-Z][\.\)]', numbering):
                    ilvl = 1
                    lvlText = "".join([i if i in ".)" else "%" for i in numbering])
                    lvlText = re.sub(r"%+", "%", lvlText)
                    label = "A,B,C…"
                    numFmt = "upperLetter"
                else: continue

                lbl = f"{label} - {lvlText}"

            
            # if list_numbering:
            # we are only interested in alphanumerics and decimals
            if numFmt not in ("lowerLetter", "upperLetter", "decimal"):
                continue
            # the 0-level criteria numbering format must be decimal
            elif numFmt in ("lowerLetter", "upperLetter") and not numbering_indent_dict:
                skip_lbls.append(lbl)
                continue
            # the higher level labels are skipped
            if lbl in skip_lbls:
                continue

            
            if numFmt == "decimal" and not numbering_indent_dict:
                ilvl = 0
                numbering_indent_dict[lbl] = ilvl
            elif numFmt in ("lowerLetter", "upperLetter") and lbl not in numbering_indent_dict:
                ilvl = 1
                numbering_indent_dict[lbl] = ilvl

            if numbering_indent_dict.get(lbl) == 0:
                # New top-level IC/EX
                current_crit_key = f"{criteria_lbl}_{crit_counter}"
                criteria_dict[current_crit_key] = 0
                crit_counter += 1
            elif numbering_indent_dict.get(lbl) == 1:
                criteria_dict[current_crit_key] += 1

            # print("-----")
            # print("text:", text)
            # print("style:", block.style.name)
            # print("block list numbering:", list_numbering)
            # print("list numbering indent dict:", numbering_indent_dict)
            # print("criteria found:", crit_counter - 1)
            # print("-----\n")

        # print(criteria_dict)
        # print(numbering_indent_dict)

        return  criteria_dict

    except Exception as e:
        print(f"Error extracting styles: {str(e)}")
        # import traceback
        # traceback.print_exc()
        return {}






# Utility 1: iterate through blocks
def iter_block_items(parent):
    if isinstance(parent, _Document):
        parent_elm = parent.element.body
    elif isinstance(parent, _Cell):
        parent_elm = parent._tc
    else:
        raise ValueError("ERROR")

    for child in parent_elm.iterchildren():
        if isinstance(child, CT_P):
            yield _Paragraph(child, parent)
        elif isinstance(child, CT_Tbl):
            yield _Table(child, parent)

# Utility 2: convert docx table to pandas DataFrame
def docx_table(block):
    data = [[cell.text.strip() for cell in row.cells] for row in block.rows]
    col_count = len(data[0]) if data else 0
    header_row = ["COL" + str(i+1) for i in range(col_count)]
    return pd.DataFrame(data, columns=header_row)

# Main Function
def get_soa_section_content(file_path):
    document = Document(file_path)
    flg_match_found = False
    t = 0
    section_contents_dict = {}
    last_para_text = ""

    # regex patterns
    soa_pattern = re.compile(
        r"(soa|schedule\s+of\s+activit(?:y|ies)(\s*\(soa\))?)",
        re.IGNORECASE
    )
    intro_pattern = re.compile(r"(introduction)", re.IGNORECASE)

    for block in iter_block_items(document):
        if isinstance(block, _Paragraph):
            text = block.text.strip()

            # Detect start of SoA section
            if not flg_match_found and soa_pattern.search(text):
                flg_match_found = True
                section_contents_dict["Header"] = text
                continue

            # Store last paragraph text (possible table title)
            if flg_match_found and text:
                last_para_text = text

            # End section at "Introduction"
            if flg_match_found and intro_pattern.search(text):
                break

        elif isinstance(block, _Table) and flg_match_found:
            t += 1
            df = docx_table(block)

            # Add table title in first row
            title_row = [last_para_text] + [""] * (len(df.columns) - 1)
            df.loc[-1] = title_row  # add title row
            df.index = df.index + 1
            df = df.sort_index()

            section_contents_dict[f"Table-{t}"] = df

    # Generate output Excel filename based on input
    base_name = os.path.splitext(os.path.basename(file_path))[0]
    output_dir = "output"
    os.makedirs(output_dir, exist_ok = True)

    output_excel =os.path.join(output_dir, f"{base_name}_soa_tables.xlsx") 


    # Write all tables to Excel (each on its own sheet)
    with pd.ExcelWriter(output_excel) as writer:
        for key, value in section_contents_dict.items():
            if isinstance(value, pd.DataFrame):
                value.to_excel(writer, sheet_name=key, index=False)

    return section_contents_dict


def extract_sections(doc_path):
    doc = Document(doc_path)
    paragraphs = list(doc.paragraphs)

    exclusion_text = []
    in_exclusion_section = False

    for para in paragraphs:
        text = para.text.strip()
        style = para.style.name if para.style else ""

        if not text:
            continue

        if style.startswith("Heading") and "exclusion criteria" in text.lower():
            in_exclusion_section = True
            continue

        if in_exclusion_section:
            if style.startswith("Heading") and "lifestyle considerations" in text.lower():
                break
            exclusion_text.append(text)

    full_text = "\n".join(p.text for p in paragraphs if p.text.strip())
    exclusion_section_text = "\n".join(exclusion_text)



    return full_text, exclusion_section_text

# NER with token length awareness
def extract_entities(text, model_name, entity_type_filter=None):
    ner = pipeline("ner", model=model_name, aggregation_strategy="max")
    CHUNK_SIZE = 400  # Number of words per chunk
    words = text.split()
    chunks = [" ".join(words[i:i+CHUNK_SIZE]) for i in range(0, len(words), CHUNK_SIZE)]

    all_entities = []
    for i, chunk in enumerate(chunks):
        try:
            entities = ner(chunk)
            filtered = [e['word'].strip() for e in entities if entity_type_filter is None or e['entity_group'] in entity_type_filter]
            all_entities.extend(filtered)
        except Exception as e:
            print(f"[ERROR] NER failed on chunk {i+1}: {e}")

    raw_entities = list(set(all_entities))
    deduped = clean_medical_entites(raw_entities)
    return deduped

# Main processing
def mh_cm_ae_extractor(file_path, output_path="extracted_data.json"):
    full_text, exclusion_text = extract_sections(file_path)

    # print("Extracting medications from full protocol...")
    all_meds = extract_entities(full_text, "d4data/biomedical-ner-all", ["Medication"])

    # print("Extracting medications from exclusion criteria...")
    exclusion_meds = extract_entities(exclusion_text, "d4data/biomedical-ner-all", ["Medication"])

    # print("Extracting diseases from full protocol...")
    all_diseases = extract_entities(full_text, "raynardj/ner-disease-ncbi-bionlp-bc5cdr-pubmed")

    # print("Extracting diseases from exclusion criteria...")
    exclusion_diseases = extract_entities(exclusion_text, "raynardj/ner-disease-ncbi-bionlp-bc5cdr-pubmed")

    final_meds = sorted(set(all_meds) - set(exclusion_meds))
    final_diseases = sorted(set(all_diseases) - set(exclusion_diseases))


    result = {
            "medications": final_meds,
            "diseases": final_diseases
        }
    

    return result


def clean_medical_entites(entities):
    cleaned = []
    for e in entities: 
        e = e.strip().lower().strip(",.;:()[]")

        if not e:
            continue
        if re.match(r"^[\d\-\.\s]+$", e):
            continue
        if len(e) < 3:
            continue
        if e in GENERIC_STOPWORDS:
            continue
        if len(e.split()) == 1 and e in GENERIC_STOPWORDS:
            continue

        cleaned.append(e)
    
    seen = set()
    final_list = []
    for x in cleaned: 
        if x not in seen:
            seen.add(x)
            final_list.append(x)
    return final_list

        











