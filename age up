                            print(f"num: {num}")
                            if num < 1 or num >100000:
                                candidates.append(num)

                        except:
                            pass
        if candidates:
            total = {
                "value": int(max(candidates)),
                "text": sent.text.strip(),
                
            }
    return {
        "total_participants": total,
        "cohort_counts": cohort
    }
    

